PORT=3000
CORS_ORIGIN=http://localhost:8081
OCR_PROVIDER_MODE=mock # 'mock' or 'real'
AI_PROVIDER=openai
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads/
DATA_DIR=data/
QUEUE_CONCURRENCY=1
JOB_POLL_INTERVAL_MS=2000
PERSISTENCE_MODE=file # 'file' or 'postgres'
DATABASE_URL=postgres://user:password@localhost:5432/anyscan
